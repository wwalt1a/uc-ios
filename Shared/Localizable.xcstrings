    "https://your-server.com:5033/": {
      "extractionState": "manual",
      "shouldTranslate": false
    },
    "INFO": {
      "extractionState": "manual",
      "shouldTranslate": false
    },
    "iOS 默认对来自其他 App 的剪贴板逐条询问——这就是每复制一条新内容、首次读取时都会弹「允许粘贴」的原因。把 设置 › UniClip › 粘贴自其他 App 设为「允许」即可完全静默(该开关在首次弹窗后才出现)。授权按 App 独立:键盘扩展可能需要在键盘内单独授权,且部分系统版本不为键盘提供该开关。": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "By default iOS asks for each clipboard item copied from another app — that's why a newly-copied item triggers “Allow Paste” the first time it's read. Set Settings › UniClip › Paste from Other Apps to Allow to silence it entirely (the switch appears only after the first prompt). Authorization is per app: the keyboard extension may need its own grant from inside the keyboard, and some iOS versions don't expose the switch for keyboards."
          }
        }
      }
    },
    "Pulled clipboard from server (%lld min ago)": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pulled clipboard from server (%lld min ago)"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已从服务器拉取（%lld 分钟前）"
          }
        }
      }
    },
